rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // -------------------------------------------------------------------------
    // HELPERS
    // -------------------------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn(); // Relaxed for the build environment
    }

    function isUser(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getRole() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid)) ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'agent') : 'agent';
    }

    function isAdmin() {
      return isSignedIn() && (request.auth.token.email == 'lancejsy16@gmail.com' || getRole() == 'admin');
    }

    function isSecretary() {
      return isAdmin() || (isVerified() && getRole() == 'secretary');
    }

    function isAgent() {
      return isAdmin() || (isVerified() && getRole() == 'agent');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // VALIDATION HELPERS
    // -------------------------------------------------------------------------

    function isValidProduct(data) {
      return data.sku is string && data.sku.size() <= 64 &&
             data.name is string && data.name.size() <= 200 &&
             data.basePrice is number && data.basePrice >= 0;
    }

    function isValidWarehouse(data) {
      return data.name is string && data.name.size() <= 100;
    }

    function isValidInventory(data) {
      return data.productId is string && data.warehouseId is string &&
             data.quantity is number;
    }

    function isValidOrder(data) {
      return data.agentId is string &&
             data.status in ['pending', 'preparing', 'out_for_delivery', 'delivered', 'completed', 'escalated'] &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             (!data.keys().contains('skus') || data.skus is list) &&
             (!data.keys().contains('statusHistory') || data.statusHistory is list);
    }

    function isValidOrderItem(data) {
      return data.orderId is string && data.productId is string &&
             data.quantity is number && data.quantity > 0;
    }

    function isValidTransfer(data) {
      return data.sourceWarehouseId is string && data.destinationWarehouseId is string &&
             data.productId is string && data.quantity is number && data.quantity > 0;
    }

    function isValidExpense(data) {
      return data.amount is number && data.amount > 0 &&
             data.date is timestamp &&
             data.category is string &&
             data.recordedBy is string &&
             (!data.keys().hasAny(['orderId']) || (data.orderId is string && data.orderId.size() <= 128));
    }

    function isValidExpenseCategory(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 64 &&
             data.isActive is bool;
    }

    function isValidUser(data) {
      return data.email is string && data.role in ['admin', 'secretary', 'agent'];
    }

    function isValidStockAdjustment(data) {
      return data.productId is string && data.warehouseId is string &&
             data.adjustmentAmount is number &&
             data.reason is string && data.reason.size() > 0 &&
             data.recordedBy is string &&
             data.timestamp is timestamp;
    }

    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // ROUTES
    // -------------------------------------------------------------------------

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidProduct(incoming());
    }

    match /warehouses/{warehouseId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin() && isValidWarehouse(incoming());
    }

    match /inventory/{inventoryId} {
      allow read: if isSignedIn();
      allow create, delete: if isSecretary() && isValidInventory(incoming());
      allow update: if isSignedIn();
    }

    match /orders/{orderId} {
      allow get: if isSignedIn() && (isSecretary() || existing().agentId == request.auth.uid);
      allow list: if isSignedIn() && (isSecretary() || resource.data.agentId == request.auth.uid);
      
      allow create: if isSignedIn();

      allow update: if isSignedIn() && (
        // Admin can do anything valid
        (isAdmin() && isValidOrder(incoming())) ||
        // Agent can only cancel if pending or update limited fields
        (isUser(existing().agentId) && isValidOrder(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt', 'statusHistory']) &&
         existing().status == 'pending') ||
        // Secretary can move to preparing/delivery and attach photo
        (isSecretary() && isValidOrder(incoming()) && 
         incoming().diff(existing()).affectedKeys().hasAny(['status', 'updatedAt', 'statusHistory', 'photoValidationUrl']) &&
         (
           (existing().status == 'pending' && incoming().status == 'preparing') ||
           (existing().status == 'preparing' && incoming().status == 'out_for_delivery' && incoming().photoValidationUrl is string) ||
           (existing().status == 'out_for_delivery' && incoming().status == 'delivered')
         ))
      );
    }

    match /orders/{orderId}/items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    match /transfers/{transferId} {
      allow read: if isSignedIn();
      allow create: if isSecretary() && isValidTransfer(incoming());
      allow update: if isSecretary() && isValidTransfer(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']);
    }

    match /expenses/{expenseId} {
      allow read: if isSecretary();
      allow create, update, delete: if isSecretary() && isValidExpense(incoming());
    }

    match /expenseCategories/{categoryId} {
      allow read: if isSignedIn();
      allow create, update: if isSecretary() && isValidExpenseCategory(incoming());
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isUser(userId) || isAdmin();
      allow create: if isSignedIn() && isUser(userId) && (
        (request.auth.token.email == 'lancejsy16@gmail.com' && incoming().role == 'admin') ||
        incoming().role == 'agent'
      );
      allow update: if isAdmin() || (isUser(userId) && isValidUser(incoming()));
    }

    match /stockAdjustments/{adjustmentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
    }
  }
}
