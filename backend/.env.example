# ─────────────────────────────────────────────
#  Anti Gravity Backend — Environment Variables
#  Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────

# Server
PORT=4000
NODE_ENV=development

# PostgreSQL connection string (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://postgres:yourpassword@localhost:5432/anti_gravity?schema=public"

# Absolute path to the frontend project root that the agent will manage.
# The agent can ONLY read/write files inside this directory.
# Default: the parent of this backend/ folder (i.e. the monorepo root)
FRONTEND_ROOT="C:/Users/DELL/Documents/APM-Life-Cycle"

# Optional: secret key for signing API tokens (if you add auth later)
API_SECRET="change-me-to-a-random-256-bit-secret"

# CORS origin(s) allowed to reach this backend (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
