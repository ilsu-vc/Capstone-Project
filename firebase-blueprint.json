{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A bike part or accessory in the catalog",
      "type": "object",
      "properties": {
        "sku": { "type": "string", "description": "Unique identifier for the item" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "basePrice": { "type": "number" },
        "wholesalePrice": { "type": "number" },
        "dealerPrice": { "type": "number" },
        "photoUrl": { "type": "string", "format": "uri" },
        "specs": { "type": "object" },
        "minStockLevel": { "type": "number" },
        "reorderPoint": { "type": "number" },
        "supplierMoq": { "type": "number" },
        "supplierId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sku", "name", "basePrice"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "A physical storage location",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "managerId": { "type": "string" }
      },
      "required": ["name"]
    },
    "Inventory": {
      "title": "Inventory",
      "description": "Stock levels for a product in a warehouse",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "warehouseId": { "type": "string" },
        "quantity": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "warehouseId", "quantity"]
    },
    "Order": {
      "title": "Order",
      "description": "A B2B order placed by an agent",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "agentId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "preparing", "out_for_delivery", "delivered", "completed", "escalated"] },
        "skus": { "type": "array", "items": { "type": "string" } },
        "totalAmount": { "type": "number" },
        "paymentStatus": { "type": "string", "enum": ["unpaid", "partially_paid", "paid", "defaulted"] },
        "deliveryRegion": { "type": "string" },
        "deliveryDeadline": { "type": "string", "format": "date-time" },
        "photoValidationUrl": { "type": "string", "format": "uri" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["agentId", "status", "totalAmount"]
    },
    "OrderItem": {
      "title": "OrderItem",
      "description": "A single line item in an order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "productId": { "type": "string" },
        "sku": { "type": "string" },
        "name": { "type": "string" },
        "quantity": { "type": "number" },
        "unitPrice": { "type": "number" },
        "subtotal": { "type": "number" }
      },
      "required": ["orderId", "productId", "quantity", "unitPrice"]
    },
    "Transfer": {
      "title": "Transfer",
      "description": "Stock transfer between warehouses",
      "type": "object",
      "properties": {
        "sourceWarehouseId": { "type": "string" },
        "destinationWarehouseId": { "type": "string" },
        "productId": { "type": "string" },
        "quantity": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "in_transit", "received"] },
        "initiatedBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["sourceWarehouseId", "destinationWarehouseId", "productId", "quantity", "status"]
    },
    "Expense": {
      "title": "Expense",
      "description": "Local business expenses for P&L mapping",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "recordedBy": { "type": "string" },
        "orderId": { "type": "string" }
      },
      "required": ["amount", "date"]
    },
    "ExpenseCategory": {
      "title": "ExpenseCategory",
      "description": "Categories for grouping expenses",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "isActive": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "isActive"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "Stored in /users/{userId}",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "secretary", "agent"] },
        "region": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "StockAdjustment": {
      "title": "StockAdjustment",
      "description": "Audit log for manual inventory adjustments",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "warehouseId": { "type": "string" },
        "adjustmentAmount": { "type": "number" },
        "reason": { "type": "string" },
        "recordedBy": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "warehouseId", "adjustmentAmount", "reason", "recordedBy", "timestamp"]
    }
  },
  "firestore": {
    "/products/{productId}": { "schema": "Product", "description": "Global product catalog" },
    "/warehouses/{warehouseId}": { "schema": "Warehouse", "description": "Physical warehouses" },
    "/inventory/{inventoryId}": { "schema": "Inventory", "description": "Real-time stock tracking" },
    "/orders/{orderId}": { "schema": "Order", "description": "Sales orders" },
    "/orders/{orderId}/items/{itemId}": { "schema": "OrderItem", "description": "Order line items" },
    "/transfers/{transferId}": { "schema": "Transfer", "description": "Warehouse stock transfers" },
    "/expenses/{expenseId}": { "schema": "Expense", "description": "Business expense logs" },
    "/expenseCategories/{categoryId}": { "schema": "ExpenseCategory", "description": "Manageable expense categories" },
    "/users/{userId}": { "schema": "UserProfile", "description": "User roles and metadata" },
    "/stockAdjustments/{adjustmentId}": { "schema": "StockAdjustment", "description": "Audit trails for stock corrections" }
  }
}
